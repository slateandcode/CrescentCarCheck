# Supabase — points at the Crescent Car Reports project (jwslaqufrdoodsxasxnr).
# Bookings/contact tables + RPCs live there (migration 006_bookings.sql in the
# Crescent Car Reports repo) — see BACKEND_SETUP.md §1.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — REQUIRED for the booking/payment flow. With these empty (and Supabase
# unset) POST /api/bookings returns 503 and the checkout form tells customers to
# WhatsApp instead. STRIPE_SECRET_KEY signs Checkout Sessions; STRIPE_WEBHOOK_SECRET
# verifies the webhook at /api/webhooks/stripe (get it from the Stripe dashboard or
# `stripe listen`). The publishable key isn't used server-side today but is kept for
# any future client-side Stripe usage.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google Maps — powers the checkout location picker (search + draggable pin).
# Enable on the key: Maps JavaScript API, Places API (New), Geocoding API.
# Restrict the key to your production domain(s). Empty = the picker hides and
# customers just type their address (booking still works).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=bookings@crescentcarcheck.com

# Business info
BUSINESS_OWNER_EMAIL=owner@crescentcarcheck.com
NEXT_PUBLIC_BUSINESS_PHONE=+971 502526314
NEXT_PUBLIC_BUSINESS_EMAIL=crescentcarcheck@gmail.com
NEXT_PUBLIC_WHATSAPP_NUMBER=971502526314
# Instagram / TikTok — the footer + mobile-menu icons default to the official
# Crescent accounts (baked into the code). Only set these to OVERRIDE the
# defaults with different profile URLs. Leave blank to use the defaults.
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_TIKTOK_URL=

# Analytics & Monitoring
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Sentry: NEXT_PUBLIC_SENTRY_DSN enables the browser SDK; SENTRY_DSN (optional)
# overrides it server-side. Both empty = monitoring stays fully dormant.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# App
# Drives Stripe success/cancel redirects + canonical/OG URLs. Leave blank here so a
# stray localhost default can't be pasted into prod.
# e.g. https://crescentcarcheck.com — MUST be the real prod URL
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_SITE_NAME=Crescent Car Check
